{
  "schema_name": "adaptive_remeshing_run_manifest_v1",
  "required": [
    "run_id",
    "classification",
    "benchmark",
    "method",
    "environment",
    "sources",
    "physics",
    "mesh",
    "loading",
    "outputs"
  ],
  "required_nested": {
    "classification": ["before_run"],
    "benchmark": ["name"],
    "method": ["type"],
    "environment": ["record_path", "runtime_target"],
    "sources": ["input_deck", "uel", "umat"],
    "physics": ["phase_field_convention", "degradation_law", "energy_split", "irreversibility"],
    "mesh": ["global_size", "local_size", "h_over_l"],
    "loading": ["steps", "increment_strategy"],
    "outputs": ["requested", "postprocessing_contract"]
  },
  "allowed_method_types": [
    "none",
    "uniform_baseline",
    "miseseri_pre_refinement",
    "evolving_remesh_state_transfer"
  ],
  "allowed_before_run_classifications": [
    "exploratory",
    "feasibility_only",
    "validation_candidate"
  ]
}
