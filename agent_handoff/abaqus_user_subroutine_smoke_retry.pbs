#!/bin/bash
#PBS -N abq_usrsub_retry
#PBS -q testq
#PBS -l select=1:ncpus=1:mem=8gb
#PBS -l walltime=00:30:00
#PBS -j oe

set -euo pipefail

module purge
module load gcc/11.4.0
module load intel/2024.2.0
module load abaqus/2023

export ABA_PARALLEL_DEBUG=1

PROJECT_REVISION="${PROJECT_REVISION:-not_provided}"

PROJECT_HOME="/home/pr21vyci/projects/adaptive-remeshing"
CASE_DIR="${PROJECT_HOME}/tests/hpc/abaqus_standard_user_subroutine_smoke"

RUN_ROOT="/scratch/pr21vyci/adaptive-remeshing/runs"
STAGE_ROOT="/scratch/pr21vyci/adaptive-remeshing/stage"

JOB_NAME="abaqus_user_subroutine_smoke_retry"
INPUT_NAME="abaqus_user_subroutine_smoke"
SOURCE_NAME="uexternaldb_smoke_getoutdir.for"
RUN_ID="${JOB_NAME}_${PBS_JOBID}"
WORK_DIR="${RUN_ROOT}/${RUN_ID}"
ABAQUS_SCRATCH="${WORK_DIR}/abaqus_scratch"
TEXT_STAGE="${STAGE_ROOT}/${RUN_ID}"

mkdir -p "${WORK_DIR}"
mkdir -p "${ABAQUS_SCRATCH}"
mkdir -p "${TEXT_STAGE}"

cp "${CASE_DIR}/${INPUT_NAME}.inp" "${WORK_DIR}/"
cp "${CASE_DIR}/${SOURCE_NAME}" "${WORK_DIR}/"

cd "${WORK_DIR}"

echo "Timestamp: $(date --iso-8601=seconds)"
echo "Host: $(hostname)"
echo "PBS job: ${PBS_JOBID}"
echo "Repository revision: ${PROJECT_REVISION}"
echo "Work directory: ${WORK_DIR}"
echo "Abaqus scratch: ${ABAQUS_SCRATCH}"
echo "Text stage: ${TEXT_STAGE}"
echo "Input file: ${INPUT_NAME}.inp"
echo "Source file: ${SOURCE_NAME}"
echo "ABA_PARALLEL_DEBUG=${ABA_PARALLEL_DEBUG}"

echo "PBS nodefile:"
cat "${PBS_NODEFILE}"

echo "Loaded modules:"
module list 2>&1

echo "Executable paths:"
command -v gcc
command -v gfortran
command -v ifx
command -v abaqus

echo "Launching Abaqus/Standard user-subroutine retry smoke test."

set +e
abaqus \
  job="${JOB_NAME}" \
  input="${INPUT_NAME}.inp" \
  user="${SOURCE_NAME}" \
  cpus=1 \
  scratch="${ABAQUS_SCRATCH}" \
  interactive
ABAQUS_RC=$?
set -e

echo "Abaqus return code: ${ABAQUS_RC}"

echo "Preserving diagnostic evidence before acceptance checks."

printf '%s\n' "${PROJECT_REVISION}" > "${TEXT_STAGE}/repository_revision.txt"
printf '%s\n' "${PBS_JOBID}" > "${TEXT_STAGE}/job_id.txt"
printf '%s\n' "${ABAQUS_RC}" > "${TEXT_STAGE}/abaqus_return_code.txt"

{
  echo "Work directory inventory"
  find "${WORK_DIR}" -maxdepth 2 -type f \
    -printf '%p\t%s\t%TY-%Tm-%Td %TH:%TM:%TS\n' 2>/dev/null
} > "${TEXT_STAGE}/work_directory_inventory.tsv" || true

{
  echo "Abaqus scratch directory inventory"
  find "${ABAQUS_SCRATCH}" -maxdepth 4 -type f \
    -printf '%p\t%s\t%TY-%Tm-%Td %TH:%TM:%TS\n' 2>/dev/null
} > "${TEXT_STAGE}/abaqus_scratch_inventory.tsv" || true

for file in \
  "${INPUT_NAME}.inp" \
  "${SOURCE_NAME}" \
  "${JOB_NAME}.com" \
  "${JOB_NAME}.log" \
  "${JOB_NAME}.msg" \
  "${JOB_NAME}.dat" \
  "${JOB_NAME}.sta" \
  "${JOB_NAME}.prt" \
  "${JOB_NAME}.env" \
  "uexternaldb_smoke.called"
do
  if [ -f "${file}" ]; then
    cp "${file}" "${TEXT_STAGE}/"
  fi
done

find "${WORK_DIR}" "${ABAQUS_SCRATCH}" -type f \
  \( -name '*.com' -o -name '*.log' -o -name '*.msg' \
     -o -name '*.dat' -o -name '*.sta' -o -name '*.prt' \
     -o -name '*.env' -o -name '*.txt' -o -name '*.pes' \
     -o -name '*.cid' \) \
  -print > "${TEXT_STAGE}/available_text_diagnostics.txt" 2>/dev/null || true

while IFS= read -r diagnostic; do
  if [ -f "${diagnostic}" ]; then
    target="${TEXT_STAGE}/$(basename "${diagnostic}")"
    if [ ! -e "${target}" ]; then
      cp "${diagnostic}" "${target}" || true
    fi
  fi
done < "${TEXT_STAGE}/available_text_diagnostics.txt"

find "${WORK_DIR}" "${ABAQUS_SCRATCH}" -type f \
  \( -iname '*.so' -o -iname '*.o' -o -iname '*.obj' \
     -o -iname '*.a' -o -iname '*.cmd' -o -iname '*standard*' \
     -o -iname '*user*' \) \
  -print > "${TEXT_STAGE}/compiler_link_artifact_candidates.txt" \
  2>/dev/null || true

{
  echo "Marker filename search"
  find "${WORK_DIR}" "${ABAQUS_SCRATCH}" -type f \
    -name 'uexternaldb_smoke.called' -print 2>/dev/null
  echo
  echo "Callback token search"
  grep -RInE \
    'UEXTERNALDB_CALLBACK_ENTERED|UEXTERNALDB_MARKER_WRITTEN|UEXTERNALDB_ANALYSIS_END|UEXTERNALDB_SMOKE_CALLED|UEXTERNALDB_MARKER_OPEN_FAILED' \
    "${WORK_DIR}" "${ABAQUS_SCRATCH}" 2>/dev/null || true
} > "${TEXT_STAGE}/callback_token_search.txt"

{
  echo "Compiler/link/library output search"
  grep -RInEi \
    'compile|link|ifx|ifort|fortran|library|load|user subroutine|warning|error|standardU|\.so|\.o|\.obj' \
    "${WORK_DIR}" "${ABAQUS_SCRATCH}" 2>/dev/null || true
} > "${TEXT_STAGE}/compile_link_library_search.txt"

{
  while IFS= read -r artifact; do
    [ -f "${artifact}" ] || continue
    echo "==== ${artifact} ===="
    file "${artifact}" 2>&1 || true
    if command -v nm >/dev/null 2>&1; then
      nm -a "${artifact}" 2>&1 | grep -i uexternaldb || true
    fi
    if command -v readelf >/dev/null 2>&1; then
      readelf -Ws "${artifact}" 2>&1 | grep -i uexternaldb || true
    fi
    if command -v strings >/dev/null 2>&1; then
      strings "${artifact}" 2>&1 | grep -E \
        'UEXTERNALDB_CALLBACK_ENTERED|UEXTERNALDB_MARKER_WRITTEN|UEXTERNALDB_ANALYSIS_END|UEXTERNALDB_SMOKE_CALLED|uexternaldb_smoke.called' \
        || true
    fi
  done < "${TEXT_STAGE}/compiler_link_artifact_candidates.txt"
} > "${TEXT_STAGE}/artifact_symbol_string_checks.txt"

MARKER_FILE="$(find "${WORK_DIR}" "${ABAQUS_SCRATCH}" -type f \
  -name 'uexternaldb_smoke.called' -print -quit 2>/dev/null || true)"

if [ -n "${MARKER_FILE}" ] && [ -f "${MARKER_FILE}" ]; then
  cp "${MARKER_FILE}" "${TEXT_STAGE}/uexternaldb_smoke.called" || true
fi

CHECKS_FAILED=0
FAILURE_CATEGORY="none"
ACCEPTANCE="${TEXT_STAGE}/acceptance_checks.txt"
: > "${ACCEPTANCE}"

record_check() {
  local name="$1"
  local status="$2"
  printf '%s: %s\n' "${name}" "${status}" | tee -a "${ACCEPTANCE}"
  if [ "${status}" != "PASS" ]; then
    CHECKS_FAILED=$((CHECKS_FAILED + 1))
    if [ "${FAILURE_CATEGORY}" = "none" ]; then
      FAILURE_CATEGORY="${name}"
    fi
  fi
}

if [ "${ABAQUS_RC}" -eq 0 ]; then
  record_check "abaqus_return_code_zero" "PASS"
else
  record_check "abaqus_return_code_zero" "FAIL"
fi

if [ -f "${JOB_NAME}.odb" ]; then
  record_check "retry_odb_exists" "PASS"
else
  record_check "retry_odb_exists" "FAIL"
fi

if [ -f "${JOB_NAME}.sta" ]; then
  record_check "retry_sta_exists" "PASS"
else
  record_check "retry_sta_exists" "FAIL"
fi

if [ -f "${JOB_NAME}.msg" ]; then
  record_check "retry_msg_exists" "PASS"
else
  record_check "retry_msg_exists" "FAIL"
fi

if [ -n "${MARKER_FILE}" ] && [ -s "${MARKER_FILE}" ]; then
  record_check "marker_exists_nonempty" "PASS"
else
  record_check "marker_exists_nonempty" "FAIL"
fi

if [ -f "${JOB_NAME}.sta" ] && grep -q \
  "THE ANALYSIS HAS COMPLETED SUCCESSFULLY" "${JOB_NAME}.sta"; then
  record_check "sta_success_message" "PASS"
else
  record_check "sta_success_message" "FAIL"
fi

if [ -f "${JOB_NAME}.msg" ] && grep -q \
  "UEXTERNALDB_CALLBACK_ENTERED" "${JOB_NAME}.msg"; then
  record_check "msg_callback_entered_token" "PASS"
else
  record_check "msg_callback_entered_token" "FAIL"
fi

if [ -f "${JOB_NAME}.msg" ] && grep -q \
  "UEXTERNALDB_MARKER_WRITTEN" "${JOB_NAME}.msg"; then
  record_check "msg_marker_written_token" "PASS"
else
  record_check "msg_marker_written_token" "FAIL"
fi

if [ -f "${JOB_NAME}.msg" ] && grep -q \
  "UEXTERNALDB_ANALYSIS_END" "${JOB_NAME}.msg"; then
  record_check "msg_analysis_end_token" "PASS"
else
  record_check "msg_analysis_end_token" "FAIL"
fi

if [ -n "${MARKER_FILE}" ] && grep -q \
  "UEXTERNALDB_SMOKE_CALLED" "${MARKER_FILE}"; then
  record_check "marker_contains_smoke_token" "PASS"
else
  record_check "marker_contains_smoke_token" "FAIL"
fi

if [ "${CHECKS_FAILED}" -eq 0 ]; then
  FINAL_CLASSIFICATION="hpc_user_subroutine_smoke_pass"
  PBS_EXIT_STATUS=0
else
  FINAL_CLASSIFICATION="hpc_user_subroutine_smoke_fail"
  PBS_EXIT_STATUS=1
fi

{
  echo "Final classification: ${FINAL_CLASSIFICATION}"
  echo "Failure category: ${FAILURE_CATEGORY}"
  echo "Checks failed: ${CHECKS_FAILED}"
  echo "ODB retained only in: ${WORK_DIR}/${JOB_NAME}.odb"
  echo "Text evidence staged at: ${TEXT_STAGE}"
} | tee "${TEXT_STAGE}/final_classification.txt"

exit "${PBS_EXIT_STATUS}"
