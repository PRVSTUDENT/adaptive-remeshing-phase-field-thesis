#!/bin/bash
#PBS -N p3sm0_serial
#PBS -q entry_imfdfkmq
#PBS -l select=1:ncpus=1:mem=16gb
#PBS -l walltime=00:30:00
#PBS -j oe
#PBS -m abe

set -uo pipefail
PROJECT_HOME="/home/pr21vyci/projects/adaptive-remeshing"
OUT="${PROJECT_HOME}/runs/hpc/stage_p/p3sm0_minimal_callback_serial"
RUN_DIR="/scratch/pr21vyci/adaptive-remeshing/runs/p3sm0_serial_${PBS_JOBID:-unknown}"
JOB_NAME="p3sm0_serial"
CLASSIFICATION="stage_p3sm0_minimal_callback_serial_fail_pre_abaqus"
ABAQUS_LAUNCHED="false"
SOLVER_EXIT="null"

mkdir -p "${OUT}" "${RUN_DIR}" || exit 2
rm -f "${OUT}/P3SM0_COMPLETION.ok"
exec > >(tee -a "${OUT}/P3SM0_PBS_STDOUT.log") \
  2> >(tee -a "${OUT}/P3SM0_PBS_STDERR.log" >&2)
source "${PROJECT_HOME}/scripts/hpc/pbs_notify.sh" 2>/dev/null || true
type pbs_notify_begin >/dev/null 2>&1 && pbs_notify_begin || true

copy_if_present() {
  local source="$1"
  local target="$2"
  if [ -f "${source}" ]; then
    cp "${source}" "${target}" 2>/dev/null || true
  fi
}

write_fallback_status() {
  if [ ! -f "${OUT}/P3SM0_STATUS.json" ]; then
    cat > "${OUT}/P3SM0_STATUS.json" <<EOF
{"classification":"${CLASSIFICATION}","P3SM0_ok":false,"job_id":"${PBS_JOBID:-unknown}","abaqus_launched":${ABAQUS_LAUNCHED},"solver_exit":${SOLVER_EXIT},"failures":["P3-SM0 stopped before all gates passed"]}
EOF
  fi
}

finalize() {
  local rc=$?
  trap - EXIT TERM INT HUP
  copy_if_present "${RUN_DIR}/${JOB_NAME}.abaqus_stdout.log" "${OUT}/${JOB_NAME}.abaqus_stdout.log"
  copy_if_present "${RUN_DIR}/${JOB_NAME}.msg" "${OUT}/${JOB_NAME}.msg"
  copy_if_present "${RUN_DIR}/${JOB_NAME}.dat" "${OUT}/${JOB_NAME}.dat"
  copy_if_present "${RUN_DIR}/${JOB_NAME}.sta" "${OUT}/${JOB_NAME}.sta"
  copy_if_present "${RUN_DIR}/${JOB_NAME}.log" "${OUT}/${JOB_NAME}.log"
  copy_if_present "${RUN_DIR}/P3SM0_COMMAND.txt" "${OUT}/P3SM0_COMMAND.txt"
  copy_if_present "${P3SM0_MANIFEST:-missing}" "${OUT}/P3SM0_LOGIN_MANIFEST.json"
  write_fallback_status
  type pbs_notify_finish >/dev/null 2>&1 && pbs_notify_finish "${rc}" || true
  exit "${rc}"
}
trap finalize EXIT
trap 'exit 143' TERM INT HUP

{
  echo "timestamp=$(date -Is)"
  echo "job_id=${PBS_JOBID:-unknown}"
  echo "host=$(hostname)"
  echo "project_revision=${PROJECT_REVISION:-missing}"
  echo "cpus=1"
  echo "mpi_ranks=1"
  echo "omp_threads=1"
  echo "OMP_NUM_THREADS=1"
  echo "mp_mode=threads"
} > "${OUT}/P3SM0_ENVIRONMENT.txt"

for variable in P3SM0_STAGE_ROOT P3SM0_MANIFEST P3SM0_DECK_SHA \
  P3SM0_SOURCE_SHA P3SM0_TRANSFER_SHA PROJECT_REVISION; do
  eval "resolved=\${${variable}:-}"
  test -n "${resolved}" || exit 3
done
for name in P3SM0_serial.inp p3sm0_minimal_callback.for \
  d2_transfer_table.inc extract_p3sm0_state.py \
  parse_p3sm0_callback_log.py validate_p3sm0_serial.py \
  validate_p3sb_baseline_serial.py; do
  test -f "${P3SM0_STAGE_ROOT}/${name}" || exit 4
done
test -f "${P3SM0_MANIFEST}" || exit 4

sha_check() {
  local expected="$1"
  local path="$2"
  local actual
  actual="$(sha256sum "${path}" | awk '{print $1}')"
  test -n "${expected}" && test "${actual}" = "${expected}"
}
sha_check "${P3SM0_DECK_SHA}" "${P3SM0_STAGE_ROOT}/P3SM0_serial.inp" || exit 5
sha_check "${P3SM0_SOURCE_SHA}" "${P3SM0_STAGE_ROOT}/p3sm0_minimal_callback.for" || exit 5
sha_check "${P3SM0_TRANSFER_SHA}" "${P3SM0_STAGE_ROOT}/d2_transfer_table.inc" || exit 5

module purge >> "${OUT}/P3SM0_ENVIRONMENT.txt" 2>&1 || true
module load gcc/11.4.0 intel/2024.2.0 abaqus/2023 \
  python/gcc/11.4.0/3.11.7 >> "${OUT}/P3SM0_ENVIRONMENT.txt" 2>&1 || exit 6
export OMP_NUM_THREADS=1
cp "${P3SM0_STAGE_ROOT}/P3SM0_serial.inp" "${RUN_DIR}/${JOB_NAME}.inp" || exit 7
cp "${P3SM0_STAGE_ROOT}/p3sm0_minimal_callback.for" "${RUN_DIR}/p3sm0_minimal_callback.for" || exit 7
cp "${P3SM0_STAGE_ROOT}/d2_transfer_table.inc" "${RUN_DIR}/d2_transfer_table.inc" || exit 7
cat > "${RUN_DIR}/P3SM0_COMMAND.txt" <<EOF
abaqus job=${JOB_NAME} input=${JOB_NAME}.inp user=p3sm0_minimal_callback.for cpus=1 mp_mode=threads output_precision=full interactive
EOF

cd "${RUN_DIR}" || exit 7
ABAQUS_LAUNCHED="true"
CLASSIFICATION="stage_p3sm0_minimal_callback_serial_fail_abaqus"
SOLVER_EXIT=0
abaqus job="${JOB_NAME}" input="${JOB_NAME}.inp" \
  user="p3sm0_minimal_callback.for" cpus=1 mp_mode=threads \
  output_precision=full interactive > "${JOB_NAME}.abaqus_stdout.log" 2>&1 ||
  SOLVER_EXIT=$?
if [ "${SOLVER_EXIT}" -ne 0 ] || [ ! -f "${JOB_NAME}.odb" ]; then
  exit 10
fi

CLASSIFICATION="stage_p3sm0_minimal_callback_serial_fail_postprocessing"
abaqus python "${P3SM0_STAGE_ROOT}/extract_p3sm0_state.py" \
  --odb "${RUN_DIR}/${JOB_NAME}.odb" --deck "${RUN_DIR}/${JOB_NAME}.inp" \
  --out-dir "${OUT}" > "${OUT}/P3SM0_EXTRACT.log" 2>&1 || exit 11
python3 "${P3SM0_STAGE_ROOT}/parse_p3sm0_callback_log.py" \
  --msg "${RUN_DIR}/${JOB_NAME}.msg" \
  --summary "${OUT}/P3SM0_CALLBACK_SUMMARY.json" \
  --events "${OUT}/P3SM0_CALLBACK_EVENTS.csv" \
  > "${OUT}/P3SM0_PARSE.log" 2>&1 || exit 12

ODB_SHA="$(sha256sum "${JOB_NAME}.odb" | awk '{print $1}')"
{
  echo "job_id=${PBS_JOBID:-unknown}"
  echo "project_revision=${PROJECT_REVISION}"
  echo "scratch_odb=${RUN_DIR}/${JOB_NAME}.odb"
  echo "scratch_odb_size=$(stat -c '%s' "${JOB_NAME}.odb")"
  echo "scratch_odb_sha256=${ODB_SHA}"
  echo "scratch_odb_mtime=$(stat -c '%y' "${JOB_NAME}.odb")"
  echo "odb_readable=true"
  echo "solver_exit=${SOLVER_EXIT}"
  echo "cpus=1"
  echo "mpi_ranks=1"
  echo "omp_threads=1"
  echo "mp_mode=threads"
  echo "mem=16gb"
  echo "walltime=00:30:00"
} > "${OUT}/P3SM0_JOB_RECORD.txt"

# Permanent ordering rule: make every validator input visible before validation.
copy_if_present "${RUN_DIR}/${JOB_NAME}.abaqus_stdout.log" "${OUT}/${JOB_NAME}.abaqus_stdout.log"
copy_if_present "${RUN_DIR}/${JOB_NAME}.sta" "${OUT}/${JOB_NAME}.sta"
copy_if_present "${RUN_DIR}/${JOB_NAME}.msg" "${OUT}/${JOB_NAME}.msg"
for required in "${OUT}/${JOB_NAME}.abaqus_stdout.log" \
  "${OUT}/${JOB_NAME}.sta" "${OUT}/P3SM0_JOB_RECORD.txt" \
  "${OUT}/P3SM0_STATE_OUTPUT.csv" "${OUT}/P3SM0_RF_U.csv" \
  "${OUT}/P3SM0_ENERGY.csv" "${OUT}/P3SM0_CALLBACK_SUMMARY.json"; do
  test -f "${required}" || exit 13
done

CLASSIFICATION="stage_p3sm0_minimal_callback_serial_fail_validation"
python3 "${P3SM0_STAGE_ROOT}/validate_p3sm0_serial.py" \
  --out-dir "${OUT}" --deck "${RUN_DIR}/${JOB_NAME}.inp" \
  --transfer "${RUN_DIR}/d2_transfer_table.inc" \
  --source "${RUN_DIR}/p3sm0_minimal_callback.for" \
  --job-id "${PBS_JOBID:-unknown}" --solver-exit "${SOLVER_EXIT}" \
  > "${OUT}/P3SM0_VALIDATE.log" 2>&1 || {
    if grep -q 'fail_callback' "${OUT}/P3SM0_STATUS.json" 2>/dev/null; then
      CLASSIFICATION="stage_p3sm0_minimal_callback_serial_fail_callback"
    fi
    exit 14
  }
CLASSIFICATION="stage_p3sm0_minimal_callback_serial_pass"
exit 0
